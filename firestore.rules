rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSessionMember(sessionId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/sessions/$(sessionId)).data.memberIds;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /sessions/{sessionId} {
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.memberIds;
      allow read: if isSignedIn();
      allow update: if isSessionMember(sessionId)
        || (isSignedIn() && request.auth.uid in request.resource.data.memberIds);
      allow delete: if isSessionMember(sessionId);
    }

    match /people/{personId} {
      allow read, write: if isSignedIn()
        && isSessionMember(resource.data.sessionId);
      allow create: if isSignedIn()
        && isSessionMember(request.resource.data.sessionId);
    }

    match /expenses/{expenseId} {
      allow read, write: if isSignedIn()
        && isSessionMember(resource.data.sessionId);
      allow create: if isSignedIn()
        && isSessionMember(request.resource.data.sessionId);
    }
  }
}
